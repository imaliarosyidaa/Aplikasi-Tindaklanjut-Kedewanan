generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  user
}

enum AspirasiStatus {
  BELUM_DITINDAKLANJUTI
  SEDANG_DITINDAKLANJUTI
  SUDAH_DITINDAKLANJUTI
  TIDAK_BISA_DITINDAKLANJUTI
}

enum SumberAspirasi {
  LEMBAR_ASPIRASI_RESES
  LEMBAR_ASPIRASI_SOSPERDA
  ASPIRASI_PROPOSAL_LANGSUNG
  KOORDINASI_DINAS_TERKAIT
  USULAN_MUSRENBANG_DEWAN
  CALL_CENTER
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String
  name      String
  role      UserRole
  aspirasis Aspirasi[]
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@map("users")
}

model Kecamatan {
  id         String      @id
  nama       String      @unique
  kelurahans Kelurahan[]
  kunjungans Kunjungan[]

  @@map("kecamatans")
}

model Kelurahan {
  id           String      @id
  kecamatan_id String
  nama         String
  kecamatan    Kecamatan   @relation(fields: [kecamatan_id], references: [id])
  kunjungans   Kunjungan[]

  @@map("kelurahans")
}

model Kunjungan {
  id             String    @id
  jenis_kegiatan String    @default("")
  tanggal        DateTime
  jam            String
  jalan          String
  kelurahan_id   String
  kecamatan_id   String
  kota           String
  link_gmaps     String    @default("")
  kelurahan    Kelurahan @relation(fields: [kelurahan_id], references: [id])
  kecamatan    Kecamatan @relation(fields: [kecamatan_id], references: [id])
  kegiatans    Kegiatan[]
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  @@map("kunjungans")
}

model Aspirasi {
  id                   String          @id
  nik                  String          @default("")
  sumber               SumberAspirasi
  deskripsi            String
  status               AspirasiStatus
  pelapor_nama         String
  pelapor_email        String
  pelapor_telepon      String
  lampiran             Json            @default("[]")
  bukti_tindak_lanjut  Json            @default("[]")
  catatan_tindak_lanjut String          @default("")
  kategori_usulan      String
  jenis_usulan         String
  jenis_reses          String
  tindak_lanjut        String
  tanggal_dibuat       DateTime
  kota                 String          @default("")
  kecamatan            String          @default("")
  kelurahan            String          @default("")
  lokasi               String          @default("")
  user_id              String?
  user                 User?           @relation(fields: [user_id], references: [id])
  created_at           DateTime        @default(now())
  updated_at           DateTime        @updatedAt

  @@map("aspirasis")
}

enum JenisKelamin {
  LAKI_LAKI
  PEREMPUAN
}

enum PosisiRelawan {
  KOORDINATOR_RW
  KOORDINATOR_RT
  KOORDINATOR_KELURAHAN
  KOORDINATOR_KECAMATAN
  FKDM
  LMK
  TOKOH_MASYARAKAT
  PROFESIONAL
}

model Relawan {
  id             String        @id @default(cuid())
  nik            String        @unique
  nama           String
  no_telepon     String
  jenis_kelamin  JenisKelamin
  kota_kabupaten String
  kecamatan      String
  kelurahan      String
  alamat         String
  posisi         PosisiRelawan
  created_at     DateTime      @default(now()) @map("created_at")
  updated_at     DateTime      @updatedAt @map("updated_at")

  @@map("relawans")
}

model Kegiatan {
  id             String    @id
  kunjungan_id   String
  isi            String
  hari           String
  tanggal        DateTime
  lokasi         String
  foto           String
  jenis_kegiatan String
  nama_kegiatan  String
  link_gmaps     String
  rt             String
  rw             String
  jumlah_peserta Int
  catatan        String
  kunjungan      Kunjungan @relation(fields: [kunjungan_id], references: [id])

  @@map("kegiatans")
}
