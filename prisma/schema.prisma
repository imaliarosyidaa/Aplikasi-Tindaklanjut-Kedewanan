generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  user
}

enum AspirasiStatus {
  BELUM_DITINDAKLANJUTI
  SEDANG_DITINDAKLANJUTI
  SUDAH_DITINDAKLANJUTI
  TIDAK_BISA_DITINDAKLANJUTI
}

enum SumberAspirasi {
  LEMBAR_ASPIRASI_RESES
  LEMBAR_ASPIRASI_SOSPERDA
  ASPIRASI_PROPOSAL_LANGSUNG
  KOORDINASI_DINAS_TERKAIT
  USULAN_MUSRENBANG_DEWAN
  CALL_CENTER
}

model User {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username  String     @unique
  email     String?    @unique
  password  String
  name      String
  role      UserRole
  aspirasis Aspirasi[]
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@map("users")
}

model Kota {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nama       String      @unique
  kecamatans Kecamatan[]
  kelurahans Kelurahan[]
  kunjungans Kunjungan[]
  relawans Relawan[]
  aspirasis Aspirasi[]

  @@map("kotas")
}

model Kecamatan {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kota_id    String      @db.Uuid
  nama       String      @unique
  kelurahans Kelurahan[]
  kunjungans Kunjungan[]
  kota       Kota        @relation(fields: [kota_id], references: [id])
  relawans Relawan[]
  aspirasis Aspirasi[]

  @@map("kecamatans")
}

model Kelurahan {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kecamatan_id String   @db.Uuid
  nama         String
  kecamatan    Kecamatan   @relation(fields: [kecamatan_id], references: [id])
  kunjungans   Kunjungan[]
  relawans Relawan[]
  aspirasis Aspirasi[]
  kotas Kota[]

  @@map("kelurahans")
}

model Kunjungan {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tanggal        DateTime
  jam            String
  jalan          String
  kelurahan_id   String  @db.Uuid
  kecamatan_id   String  @db.Uuid
  kota_id        String  @db.Uuid
  link_gmaps     String?    @default("")
  kelurahan    Kelurahan @relation(fields: [kelurahan_id], references: [id])
  kecamatan    Kecamatan @relation(fields: [kecamatan_id], references: [id])
  kota         Kota        @relation(fields: [kota_id], references: [id])
  kegiatans    Kegiatan[]
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  @@map("kunjungans")
}

model Aspirasi {
  id                   String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nik                  String?          @default("")
  sumber               SumberAspirasi
  deskripsi            String
  status               AspirasiStatus
  pelapor_nama         String
  pelapor_email        String?    @default("")
  pelapor_telepon      String
  lampiran             Json?            @default("[]")
  bukti_tindak_lanjut  Json?            @default("[]")
  catatan_tindak_lanjut String?          @default("")
  kategori_usulan      String
  jenis_usulan         String
  jenis_reses          String
  tindak_lanjut        String
  tanggal_dibuat       DateTime
  kota_id              String?         @db.Uuid
  kecamatan_id         String?         @db.Uuid
  kelurahan_id         String?         @db.Uuid
  alamat               String?
  user_id              String?         @db.Uuid
  created_at           DateTime        @default(now())
  updated_at           DateTime        @updatedAt

  user                 User?           @relation(fields: [user_id], references: [id])
  kota                 Kota?           @relation(fields: [kota_id], references: [id])
  kecamatan            Kecamatan?      @relation(fields: [kecamatan_id], references: [id])
  kelurahan            Kelurahan?      @relation(fields: [kelurahan_id], references: [id])
  @@map("aspirasis")
}

enum JenisKelamin {
  LAKI_LAKI
  PEREMPUAN
}

enum PosisiRelawan {
  KOORDINATOR_RW
  KOORDINATOR_RT
  KOORDINATOR_KELURAHAN
  KOORDINATOR_KECAMATAN
  FKDM
  LMK
  TOKOH_MASYARAKAT
  PROFESIONAL
}

model Relawan {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nik            String?        @unique
  nama           String
  no_telepon     String?
  jenis_kelamin  JenisKelamin
  alamat         String
  posisi         PosisiRelawan
  foto           String?
  created_at     DateTime      @default(now()) @map("created_at")
  updated_at     DateTime      @updatedAt @map("updated_at")
  kota_id        String  @db.Uuid
  kecamatan_id   String  @db.Uuid
  kelurahan_id   String  @db.Uuid

  kota           Kota        @relation(fields: [kota_id], references: [id])
  kecamatan      Kecamatan   @relation(fields: [kecamatan_id], references: [id])
  kelurahan      Kelurahan   @relation(fields: [kelurahan_id], references: [id])
  @@map("relawans")
}

model Kegiatan {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  jenis_kegiatan String    @default("")
  kunjungan_id   String  @db.Uuid
  isi            String?
  hari           String?
  tanggal        DateTime?
  foto           String?
  nama_kegiatan  String
  link_gmaps     String?
  tempat         String?
  alamat         String?
  rt             String?
  rw             String?
  jumlah_peserta Int?
  catatan        String?
  kunjungan      Kunjungan @relation(fields: [kunjungan_id], references: [id])

  @@map("kegiatans")
}
